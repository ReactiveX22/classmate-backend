# DATABASE_URL=postgresql://postgres:password@localhost:5432/classmate

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

CLIENT_URL=http://localhost:3001

# For docker 
DATABASE_URL=postgres://postgres:password@host.docker.internal:5432/classmate

# Mail Configuration
# Options for MAIL_SERVICE: google, mailtrap, null
MAIL_SERVICE=null

MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@classmate.dev

# Storage Configuration
# Options for STORAGE_SERVICE: local, minio, s3
STORAGE_SERVICE=local

# S3/MinIO Configuration (required when STORAGE_SERVICE=minio or s3)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=classmate
STORAGE_PUBLIC_URL=http://localhost:9000/classmate