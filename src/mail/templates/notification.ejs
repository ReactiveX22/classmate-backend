<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <style>
      body {
        font-family: sans-serif;
        line-height: 1.6;
        color: #333;
      }
      .container {
        max-width: 600px;
        margin: 20px auto;
        padding: 20px;
        border: 1px solid #eee;
        border-radius: 8px;
      }
      .header {
        border-bottom: 2px solid #f4f4f4;
        padding-bottom: 10px;
        margin-bottom: 20px;
      }
      .footer {
        margin-top: 30px;
        font-size: 12px;
        color: #888;
        border-top: 1px solid #eee;
        padding-top: 10px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h2><%= subject %></h2>
      </div>
      <div class="content">
        <p>Hi <%= recipientName || 'there' %>,</p>
        <p><%= content %></p>
      </div>
      <div class="footer">
        <p>Sent from Classmate</p>
      </div>
    </div>
  </body>
</html>
