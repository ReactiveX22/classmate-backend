DATABASE_URL=postgresql://postgres:password@localhost:5432/classmate-test

BETTER_AUTH_SECRET=your-auth-secret
BETTER_AUTH_URL=http://localhost:3000

CLIENT_URL=http://localhost:3001

# Mail Configuration
# Options for MAIL_SERVICE: google, smtp, null
MAIL_SERVICE=smtp

SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_USER=test
MAIL_PASS=test
MAIL_FROM=noreply@classmate.dev

# Storage Configuration
# Options for STORAGE_SERVICE: local, minio, s3
STORAGE_SERVICE=local

# S3/MinIO Configuration (required when STORAGE_SERVICE=minio or s3)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=classmate
STORAGE_PUBLIC_URL=http://localhost:9000/classmate

# Cache Configuration
# Options for CACHE_STORE: null, memory, redis
CACHE_STORE=memory
CACHE_TTL=30
CACHE_MAX_ITEMS=100
# CACHE_REDIS_URL=